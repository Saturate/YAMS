# YAMS Server Configuration
# Copy to .env and adjust as needed

# Server port (default: 3000)
# YAMS_PORT=3000

# SQLite database path (default: data/yams.db, /data/yams.db in Docker)
# YAMS_DB_PATH=data/yams.db

# JWT secret for session tokens (auto-generated and stored in DB if not set)
# YAMS_JWT_SECRET=

# Qdrant vector database URL (default: http://localhost:6333)
# QDRANT_URL=http://localhost:6333

# Ollama embedding service (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768
