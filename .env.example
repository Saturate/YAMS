# HUSK Server Configuration
# Copy to .env and adjust as needed.
# You can also use husk.toml — see server/husk.toml.example.

# --- Server ---
# HUSK_PORT=3000
# HUSK_DB_PATH=data/husk.db
# HUSK_JWT_SECRET=

# --- Storage ---
# HUSK_STORAGE=qdrant                    # qdrant | sqlite-vec
# HUSK_STORAGE_URL=http://localhost:6333  # qdrant endpoint
# HUSK_STORAGE_PATH=data/husk-vectors.db  # sqlite-vec file path

# --- Embeddings ---
# HUSK_EMBEDDINGS=ollama                  # ollama | transformers | voyage | openai | llamacpp
# HUSK_EMBED_URL=                         # provider endpoint (each has a sensible default)
# HUSK_EMBED_MODEL=                       # model name (each has a sensible default)
# HUSK_EMBED_API_KEY=                     # required for voyage, openai
# HUSK_EMBED_DIMENSIONS=                  # 0 = provider default
# HUSK_EMBED_MODELS_PATH=data/models      # transformers model cache

# --- Compression ---
# HUSK_COMPRESSION_PROVIDER=anthropic     # anthropic | openrouter | ollama
# HUSK_COMPRESSION_API_KEY=
# HUSK_COMPRESSION_MODEL=
# HUSK_COMPRESSION_URL=
# HUSK_COMPRESSION_MODE=client            # client | server

# --- Auth (GitHub OAuth) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# OAUTH_ALLOWED_ORGS=
