{
	"name": "@huskai/cli",
	"version": "0.1.0",
	"description": "CLI wizard for HUSK — memory layer for AI coding assistants",
	"type": "module",
	"bin": {
		"husk": "./dist/bin.js"
	},
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Saturate/HUSK.git",
		"directory": "cli"
	},
	"homepage": "https://github.com/Saturate/HUSK/tree/main/cli",
	"bugs": {
		"url": "https://github.com/Saturate/HUSK/issues"
	},
	"keywords": ["ai", "memory", "coding-assistant", "mcp", "cli"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "bun test",
		"prepublishOnly": "tsup",
		"changelog": "git-cliff --include-path 'cli/**' -o cli/CHANGELOG.md"
	},
	"dependencies": {
		"@clack/prompts": "^0.10",
		"smol-toml": "^1.6.0",
		"zod": "^3.24"
	},
	"devDependencies": {
		"@types/node": "^22",
		"tsup": "^8",
		"typescript": "^5.9"
	},
	"files": [
		"dist"
	],
	"license": "MIT"
}
